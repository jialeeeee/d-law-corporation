# ─────────────────────────────────────────────────────────────────────────────
# Justifi environment — copy this file to `.env.local` and fill in real values.
# `.env.local` is git-ignored. NEVER commit real secrets. (agent.md §0.2, §0.7)
# ─────────────────────────────────────────────────────────────────────────────

# Agnes AI (OpenAI-compatible gateway). SERVER-SIDE ONLY.
# Used only inside route handlers via lib/agnes/client.ts.
# Do NOT prefix with NEXT_PUBLIC_ and never reference it in client components.
AGNES_KEY=
AGNES_BASE_URL=https://apihub.agnes-ai.com/v1

# Audio transcription (F2). Agnes has NO speech-to-text model, so point these at
# any OpenAI-compatible Whisper endpoint to enable audio (supports
# .ogg/.mp3/.wav/.m4a/.webm/.flac, etc.). Falls back to AGNES_* if unset (which
# fails fast with a clear message). RECOMMENDED: Groq's free tier —
#   TRANSCRIBE_BASE_URL=https://api.groq.com/openai/v1
#   TRANSCRIBE_API_KEY=gsk_...        # free key from console.groq.com
#   TRANSCRIBE_MODEL=whisper-large-v3
# Or OpenAI (paid): base https://api.openai.com/v1, key sk-..., model whisper-1.
# AGNES_AUDIO_MODEL=whisper-1

# Database — Supabase Postgres.
# DATABASE_URL  = pooled connection (PgBouncer, port 6543) used at runtime.
# DIRECT_URL    = direct connection (port 5432) used by `prisma db push` / migrations.
DATABASE_URL=
DIRECT_URL=

# Supabase Auth (login / registration).
# These two are BROWSER-SAFE (unlike the keys above) — the anon key is meant to
# be public. Find them in Supabase: Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
