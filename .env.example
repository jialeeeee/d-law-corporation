# ─────────────────────────────────────────────────────────────────────────────
# Justifi environment — copy this file to `.env.local` and fill in real values.
# `.env.local` is git-ignored. NEVER commit real secrets. (agent.md §0.2, §0.7)
# ─────────────────────────────────────────────────────────────────────────────

# Agnes AI (OpenAI-compatible gateway). SERVER-SIDE ONLY.
# Used only inside route handlers via lib/agnes/client.ts.
# Do NOT prefix with NEXT_PUBLIC_ and never reference it in client components.
AGNES_KEY=
AGNES_BASE_URL=https://apihub.agnes-ai.com/v1

# Optional: enable the (unconfirmed) Agnes OpenAI-compatible audio endpoint for
# transcription. Track 3 must verify this in the Agnes dashboard. If unavailable,
# wire a swappable provider (Whisper / AssemblyAI / local) — see lib/agnes/client.ts.
# AGNES_AUDIO_MODEL=whisper-1

# Database — Supabase Postgres.
# DATABASE_URL  = pooled connection (PgBouncer, port 6543) used at runtime.
# DIRECT_URL    = direct connection (port 5432) used by `prisma db push` / migrations.
DATABASE_URL=
DIRECT_URL=
