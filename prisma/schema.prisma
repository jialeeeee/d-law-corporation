// Justifi data model (agent.md §5). The Lead owns this file — change via PR.
// Scope (2026-06-15): supports Feature 2 (Evidence + audio) and Feature 6
// (Hearing script + mock Q&A). PDPA: store the minimum; never log raw narratives.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Pooled connection (Supabase PgBouncer, port 6543) used at runtime.
  url       = env("DATABASE_URL")
  // Direct connection (port 5432) used by `prisma db push` / migrations.
  directUrl = env("DIRECT_URL")
}

// App-level user profile, one row per Supabase Auth user. The row is created
// automatically by the `on_auth_user_created` trigger on signup (see
// supabase/migrations/0001_profiles_and_auth.sql), which also adds the
// id -> auth.users(id) foreign key that Prisma can't express across schemas.
// `id` here equals the Supabase auth uid (= Case.userId).
model Profile {
  id        String   @id @db.Uuid
  email     String?
  fullName  String?  @map("full_name")
  // App-wide UI preferences (theme, reminders, language). The hearing-prep
  // workspace persists these here so nothing lives only in the browser.
  prefs     Json?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("profiles")
}

model Case {
  id        String   @id @default(cuid())
  // Owner = Supabase Auth user id (uuid). Nullable for now so in-progress F2/F6
  // work isn't broken; ALWAYS filter Case/Evidence queries by userId (Prisma
  // bypasses Supabase RLS, so ownership is enforced in app code). See agent.md §5a.
  userId    String?
  title     String?
  status    String   @default("draft")

  // ── Hearing-prep workspace header (feat/hearing-prep-ui) ──
  // Display-oriented case metadata shown in the workspace top bar / dashboard.
  // Nullable so a freshly created blank case carries no fabricated content.
  caseNo      String?
  tribunal    String?
  claimant    String?
  respondent  String?
  amountStr   String?
  hearingISO  String?
  hearingDate String?
  hearingTime String?
  room        String?

  // Feature 6 — witness statement input + generated hearing script (HearingScript).
  statement     String?
  hearingScript Json?

  // ── Workspace display state (owned by the client store, persisted as JSON) ──
  // These mirror the UI's CaseData arrays. They are derived from the user's own
  // uploads/edits — never seeded with demo content.
  evidenceItems  Json?
  timeline       Json?
  qa             Json?
  checklist      Json?
  exportOpts     Json?
  factGroups     Json?
  scriptSections Json?
  scriptReviewed Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  evidence Evidence[]
  facts    MaterialFact[]

  @@index([userId])
}

model Evidence {
  id             String        @id @default(cuid())
  caseId         String
  case           Case          @relation(fields: [caseId], references: [id], onDelete: Cascade)
  // "image" | "audio" — see EvidenceKind in lib/types.ts.
  kind           String
  sourceFile     String
  // Structured extract: EvidenceExtract (image) or Transcript (audio).
  extract        Json?
  evidenceLinked Boolean       @default(false)
  // Optional link to the material fact this evidence supports.
  factId         String?
  fact           MaterialFact? @relation(fields: [factId], references: [id])
  createdAt      DateTime      @default(now())

  @@index([caseId])
}

model MaterialFact {
  id             String     @id @default(cuid())
  caseId         String
  case           Case       @relation(fields: [caseId], references: [id], onDelete: Cascade)
  statement      String
  sourceQuote    String?
  evidenceLinked Boolean    @default(false)
  evidence       Evidence[]
  createdAt      DateTime   @default(now())

  @@index([caseId])
}
